{
  "name": "inmates-career-advocate",
  "version": "0.1.0",
  "description": "Conversational AI agent for job discovery on inmates.ai platform",
  "author": "",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=4096 tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:api": "tsx src/test-api.ts",
    "test:query-builder": "tsx src/test-query-builder.ts",
    "test:agent": "tsx src/test-agent.ts",
    "test:phase5": "tsx src/test-phase5.ts",
    "test:unit:query": "tsx src/tests/unit/query-builder.test.ts",
    "test:unit:api": "tsx src/tests/unit/api-client.test.ts",
    "test:integration": "tsx src/tests/integration/agent-validation.test.ts",
    "test:conversation": "tsx src/tests/integration/conversational-history.test.ts",
    "test:all": "tsx src/tests/run-all-tests.ts",
    "extract-token": "tsx src/extract-token.ts"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/openai": "^0.3.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
